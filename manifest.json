{
  "manifest_version": 3,
  "name": "Gentle Reader",
  "version": "1.1.0",
  "description": "Highlight text → Right-click → 'Gentle Reader: Read Aloud' → Wavenet-C voice reads softly while highlighting words.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "128": "icon.png"
  },
  "web_accessible_resources": [{
    "resources": ["styles.css"],
    "matches": ["<all_urls>"]
  }]
}
